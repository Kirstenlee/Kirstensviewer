<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<!-- KV Quick Chat - Compact chat bar for immersive in-world chatting
     Copyright (C) 2024 KV - Licensed under MIT License -->
<floater
  bg_opaque_image="Window_NoTitle_Foreground"
  bg_alpha_image="Window_NoTitle_Background"
  can_resize="true"
  can_minimize="false"
  can_close="false"
  can_drag_on_left="false"
  can_tear_off="false"
  can_dock="false"
  show_title="false"
  header_height="0"
  legacy_header_height="0"
  save_rect="true"
  save_visibility="false"
  single_instance="true"
  height="32"
  min_height="32"
  max_height="32"
  layout="topleft"
  name="kv_quick_chat"
  title="Q Chat"
  width="400"
  min_width="200"
  max_width="800">

  <!-- Chat input field -->
  <line_editor
   border_style="line"
   border_thickness="1"
   follows="left|right|top"
   height="23"
   label="Type to chat..."
   layout="topleft"
   left="4"
   right="-32"
   top="4"
   max_length_bytes="1023"
   name="chat_box"
   spellcheck="true"
   text_pad_left="5"
   text_pad_right="5"
   tool_tip="Press Enter to say, Ctrl+Enter to shout, ESC to close" />

  <!-- Emoji picker button -->
  <button
   follows="right|top"
   height="23"
   image_overlay="Emoji_Picker_Icon"
   layout="topleft"
   name="emoji_picker_btn"
   tool_tip="Insert emoji"
   top="4"
   right="-4"
   width="23" />

</floater>
