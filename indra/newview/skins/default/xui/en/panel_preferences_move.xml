<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
 border="true"
 follows="left|top|right|bottom"
 height="408"
 label="Move"
 layout="topleft"
 left="102"
 name="move_panel"
 top="1"
 width="517">
  
  <slider
   can_edit_text="true"
   control_name="CameraAngle"
   decimal_digits="2"
   follows="left|top"
   height="16"
   increment="0.025"
   initial_value="1.57"
   layout="topleft"
   label_width="100"
   label="View angle"
   left="30"
   max_val="2.97"
   min_val="0.17"
   name="camera_fov"
     show_text="true"
   width="240" />
     <slider
     can_edit_text="true"
     control_name="DynamicCameraStrength"
     decimal_digits="2"
     follows="left|top"
     height="16"
     increment="1"
     initial_value="2"
     layout="topleft"
     label="Camera Lag"
     left_delta="0"
     label_width="100"
     max_val="60"
     min_val="0"
     name="camera_lag"
     show_text="true"
     width="240"
     top="22"/>
  <slider
   can_edit_text="true"
   control_name="CameraOffsetScale"
   decimal_digits="2"
   follows="left|top"
   height="16"
   increment="0.025"
   initial_value="1"
   layout="topleft"
   label="Distance"
   left_delta="0"
   label_width="100"
   max_val="3"
   min_val="0.5"
   name="camera_offset_scale"
     show_text="true"
   width="240"
   top="39"/>
     <slider
     can_edit_text="true"
     control_name="CameraPositionSmoothing"
     decimal_digits="2"
     follows="left|top"
     height="16"
     increment="0.025"
     initial_value="1"
     layout="topleft"
     label="Smoothing"
     left_delta="0"
     label_width="100"
     max_val="40"
     min_val="0.5"
     name="camera_position_smoothing"
     show_text="true"
     width="240"
     top="55"/>
     <slider
     can_edit_text="true"
     control_name="ZoomTime"
     decimal_digits="2"
     follows="left|top"
     height="16"
     increment="0.05"
     initial_value="1"
     layout="topleft"
     label="Zoom Time"
     left_delta="0"
     label_width="100"
     max_val="10"
     min_val="0"
     name="zoomtime"
     show_text="true"
     width="240"
     top="71"/>
     <check_box
     control_name="DisableCameraConstraints"
     follows="left|top"
     height="20" initial_value="false"
     label="Disable Camera Constraints"
     layout="topleft"
     left="20"
     name="DisableCameraConstraints"
     tool_tip="Disables the Camera Constrains which prevent your Camera from moving infinite in all directions dependless of the View Distance"
     width="200"
     top="90"/>
     <text
  follows="left|top"
  type="string"
  length="1"
  height="10"
  layout="topleft"
  left="360"
  name="track_lbl"
  width="110"
  top="50">
    Headtrack  Intensity:
  </text>
     <slider
     can_edit_text="true"
     control_name="PitchFromMousePosition"
     orientation="vertical"
     decimal_digits="0"
     follows="left|top"
     height="90"
     increment="1"
     initial_value="45"
     layout="topleft"
     label="V"
     left="320"
     label_width="10"
     max_val="90"
     min_val="0"
     name="pitchfrommouse"
     show_text="false"
     width="26"
     top="20"/>
     <slider
     can_edit_text="true"
     control_name="YawFromMousePosition"
     decimal_digits="0"
     follows="left|top"
     height="16"
     increment="1"
     initial_value="45"
     layout="topleft"
     label="H"
     left="330"
     label_width="10"
     max_val="180"
     min_val="0"
     name="yawfrommouse"
     show_text="false"
     width="130"
     top="1"/>
  <text
  follows="left|top"
  type="string"
  length="1"
  height="10"
  layout="topleft"
  left="10"
  name="position_lbl"
  width="140"
  top="117">
    Auto position and actions:
  </text>
  <check_box
     control_name="EditCameraMovement"
     height="20"
     follows="left|top"
     label="Build/Edit"
     layout="topleft"
     left="20"
     name="edit_camera_movement"
     tool_tip="Use automatic camera positioning when entering and exiting edit mode"
     width="100"
     top="138" />
  <check_box
   control_name="AppearanceCameraMovement"
   follows="left|top"
   height="16"
   label="Appearance"
   layout="topleft"
   name="appearance_camera_movement"
   tool_tip="Use automatic camera positioning while in edit mode"
   width="100" />
  
  <text
   follows="left|top"
   type="string"
   length="1"
   height="10"
   layout="topleft"
   left="10"
   name="keyboard_lbl"
   width="60"
   top="190">
    Keyboard:
  </text>
  <check_box
   control_name="ArrowKeysAlwaysMove"
   follows="left|top"
   height="20"
   label="Arrow keys always move me in chat"
   layout="topleft"
   left="20"
   name="arrow_keys_move_avatar_check"
   width="137"
   top="210"/>
  <check_box
   control_name="AllowTapTapHoldRun"
   follows="left|top"
   height="20"
   label="Tap-tap-hold to run"
   layout="topleft"
   left="20"
   name="tap_tap_hold_to_run"
   width="237"
   top="230"/>
  <check_box
   control_name="AutomaticFly"
   follows="left|top"
   height="20"
   label="Hold jump or crouch key to start or stop flying"
   layout="topleft"
   left="20"
   name="automatic_fly"
   width="137"
   top="250"/>
  <text
   follows="left|top"
   type="string"
   length="1"
   height="10"
   layout="topleft"
   left="10"
   name="mouse_lbl"
   width="70"
   top="275">
    Mouse:
  </text>
  <check_box
   control_name="FirstPersonAvatarVisible"
   follows="left|top"
   height="20"
   label="Show me in Mouselook"
   layout="topleft"
   left="20"
   name="first_person_avatar_visible"
   top="295"
   width="70" />
  <text
   type="string"
   length="1"
   follows="left|top"
   height="15"
   layout="topleft"
   left="30"
   name=" Mouse Sensitivity"
   top="320"
   width="150"
   wrap="true">
    Mouselook sensitivity:
  </text>
  <slider
   control_name="MouseSensitivity"
   follows="left|top"
   height="15"
   initial_value="2"
   layout="topleft"
   show_text="false"
   left_pad="0"
   max_val="15"
   name="mouse_sensitivity"
   top="320"
   width="115" />
  <check_box
   control_name="InvertMouse"
   height="16"
   label="Invert"
   layout="topleft"
   left_pad="2"
   name="invert_mouse"
   top="320"
   width="128" />
  <text
   follows="left|top"
   type="string"
   length="1"
   height="10"
   layout="topleft"
   left="30"
   name="mouse_warp_lbl"
   width="150"
   top_pad="60">
    Mouse Warp:
  </text>
  <combo_box
   control_name="MouseWarpMode"
   height="23"
   layout="topleft"
   left_pad="10"
   top_delta="-6"
   name="mouse_warp_combo"
   tool_tip="Controls warping of the mouse to the center of the screen during alt-zoom and mouse look."
   width="60">
    <combo_box.item
     label="Automatic"
     name="0"
     value="0"/>
    <combo_box.item
     label="On"
     name="1"
     value="1"/>
    <combo_box.item
     label="Off"
     name="2"
     value="2"/>
  </combo_box>
  <text
   follows="left|top"
   type="string"
   length="1"
   height="10"
   layout="topleft"
   left="190"
   name="single_click_action_lbl"
   width="120"
   top="145">
    Single click on land:
  </text>
  <combo_box
   height="23"
   layout="topleft"
   left_pad="10"
   top="140"
   name="single_click_action_combo"
   width="130">
    <combo_box.item
     label="No action"
     name="0"
     value="0"/>
    <combo_box.item
     label="Move to clicked point"
     name="1"
     value="1"/>
    <combo_box.commit_callback
     function="Pref.ClickActionChange"/>
  </combo_box>
  <text
   follows="left|top"
   type="string"
   length="1"
   height="10"
   layout="topleft"
   left="190"
   name="double_click_action_lbl"
   width="120"
   top="165">
    Double click on land:
  </text>
  <combo_box
   height="23"
   layout="topleft"
   left_pad="10"
   top="165"
   name="double_click_action_combo"
   width="130">
    <combo_box.item
     label="No action"
     name="0"
     value="0"/>
    <combo_box.item
     label="Move to clicked point"
     name="1"
     value="1"/>
    <combo_box.item
     label="Teleport to clicked point"
     name="2"
     value="2"/>
    <combo_box.commit_callback
     function="Pref.ClickActionChange"/>
  </combo_box>
  <check_box
   control_name="EnableCollisionSounds"
   height="20"
   label="Play sound on collisions"
   layout="topleft"
   left="20"
   name="sound_on_collisions"
   top="340"
   width="200" />
    <check_box
     control_name="ShowCrosshairs"
     follows="left|top"
     height="20"
     label="Show Crosshairs in Mouselook"
     layout="topleft"
     left="20"
     name="ShowCrosshairs"
     width="256" />
  <button
   height="23"
   label="Other Devices"
   layout="topleft"
   left="320"
   name="joystick_setup_button"
   top="360"
   width="140">
    <button.commit_callback
     function="Floater.Show"
     parameter="pref_joystick" />
  </button>
</panel>
