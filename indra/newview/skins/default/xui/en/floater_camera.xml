<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater
 positioning="specified"
 right="-460"
 bottom="-50"
 follows="left|bottom"
 legacy_header_height="18"
 can_minimize="true"
 can_close="true"
 height="195"
 layout="topleft"
 name="camera_floater"
 help_topic="camera_floater"
 save_visibility="true"
 single_instance="true"
 title="CAMERA CONTROLS"
 chrome="true"
 save_rect="true"
 width="400">
    <floater.string
     name="rotate_tooltip">
        Rotate Camera Around Focus
    </floater.string>
    <floater.string
     name="zoom_tooltip">
        Zoom Camera Towards Focus
    </floater.string>
    <floater.string
     name="move_tooltip">
        Move Camera Up and Down, Left and Right
    </floater.string>
    <floater.string
     name="free_mode_title">
        View Object
    </floater.string>
    <string name="inactive_combo_text">Use preset</string>

    <!-- Tab container for Camera Controls and Framing -->
    <tab_container
     follows="all"
     height="170"
     halign="center"
     layout="topleft"
     left="5"
     name="camera_tabs"
     tab_min_width="90"
     tab_height="20"
     tab_position="top"
     top="20"
     width="390">

      <!-- TAB 1: Camera Controls -->
      <panel
       border="true"
       follows="all"
       height="150"
       label="Controls"
       layout="topleft"
       left="1"
       name="tab_controls"
       top="20"
       width="388">
    <panel
     border="false"
     height="123"
     layout="topleft"
     left="2"
     top="0"
     mouse_opaque="false"
     name="controls"
     width="220">
         <!--TODO: replace + - images -->
         <panel
            border="false"
            class="camera_zoom_panel"
            height="123"
            layout="topleft"
            left="0"
            mouse_opaque="false"
            name="zoom"
            top="0"
            width="220">
           <joystick_rotate
              follows="top|left"
              height="78"
              layout="topleft"
              left="7"
              name="cam_rotate_stick"
              quadrant="left"
              sound_flags="3"
              visible="true"
              tool_tip="Orbit camera around focus"
              top="25"
              width="78" />
           <button
              follows="top|left"
              height="18"
              image_disabled="AddItem_Disabled"
              image_selected="AddItem_Press"
              image_unselected="AddItem_Off"
              layout="topleft"
              left_pad="14" 
              name="zoom_plus_btn"
              width="18"
              top="23">
             <commit_callback
                function="Zoom.plus" />
             <mouse_held_callback
                function="Zoom.plus" />
           </button>
           <slider_bar
              height="50"
              layout="topleft"
              name="zoom_slider"
              orientation="vertical"
              tool_tip="Zoom camera toward focus"
              top_pad="0"
              min_val="0"
              max_val="1"
              increment="0.02"
              width="18">
             <commit_callback function="Slider.value_changed"/>
           </slider_bar>
           <button
              follows="top|left"
              height="18"
              image_disabled="MinusItem_Disabled"
              image_selected="MinusItem_Press"
              image_unselected="MinusItem_Off"
              layout="topleft"
              name="zoom_minus_btn"
              top_pad="0"
              width="18">
             <commit_callback
                function="Zoom.minus" />
             <mouse_held_callback
                function="Zoom.minus" />
           </button>
         <joystick_track
         follows="top|left"
         height="78"
         image_selected="Cam_Tracking_In"
         image_unselected="Cam_Tracking_Out"
         layout="topleft"
         left="133"
         name="cam_track_stick"
         quadrant="left"
         scale_image="false"
         sound_flags="3"
         tool_tip="Move camera up and down, left and right"
         top="25"
         width="78"/>
         <text
          type="string"
          length="1"
          follows="left|top"
          height="15"
          layout="topleft"
          left="41"
          top_pad="9"
          name="precise_ctrs_label"
          width="200">
            Use precise controls
        </text>
        </panel>
    </panel>
    <panel
     follows="left|top"
     height="102"
     layout="topleft"
     left_pad="2"
     right="-2"
     name="buttons_panel"
     top="22">
    <panel_camera_item
      name="front_view"
      tool_tip="Front View"
      width="30">
      <panel_camera_item.mousedown_callback
        function="CameraPresets.ChangeView"
        parameter="Front View" />
      <panel_camera_item.picture
        image_name="Cam_Preset_Front_Off" />
      <panel_camera_item.selected_picture
        image_name="Cam_Preset_Front_On" />
    </panel_camera_item>
    <panel_camera_item
      name="group_view"
      tool_tip="Side View"
      width="30"
      left_pad="4">
      <panel_camera_item.mousedown_callback
        function="CameraPresets.ChangeView"
        parameter="Side View" />
      <panel_camera_item.picture
        image_name="Cam_Preset_Side_Off" />
      <panel_camera_item.selected_picture
        image_name="Cam_Preset_Side_On" />
    </panel_camera_item>
    <panel_camera_item
      name="rear_view"
      tool_tip="Rear View"
      width="30"
      left_pad="4">
      <panel_camera_item.mousedown_callback
        function="CameraPresets.ChangeView"
        tool_tip="Rear View"
        parameter="Rear View" />
      <panel_camera_item.picture
        image_name="Cam_Preset_Back_Off" />
      <panel_camera_item.selected_picture
        image_name="Cam_Preset_Back_On" />
    </panel_camera_item>
    <panel_camera_item
        name="object_view"
        tool_tip="Object View"
        width="30"
        left_pad="4">
        <panel_camera_item.mousedown_callback
          function="CameraPresets.ChangeView"
          parameter="object_view" />
        <panel_camera_item.picture
          image_name="Object_View_Off" />
        <panel_camera_item.selected_picture
          image_name="Object_View_On" />
      </panel_camera_item>
      <panel_camera_item
        name="mouselook_view"
        tool_tip="Mouselook View"
        width="30"
        left_pad="4">
        <panel_camera_item.mousedown_callback
          function="CameraPresets.ChangeView"
          parameter="mouselook_view" />
        <panel_camera_item.picture
          image_name="MouseLook_View_Off" />
        <panel_camera_item.selected_picture
          image_name="MouseLook_View_On" />
      </panel_camera_item>
      <combo_box
        height="23"
        left="0"
        mouse_opaque="true"
        name="preset_combo"
        top_pad="10"
        width="136">
        <combo_list
        mouse_wheel_opaque="true"/>
        <combo_box.item
         label="Use preset"
         name="Use preset"
         value="default" />
      </combo_box>
      <button
        height="16"
        width="16"  
        layout="topleft"
        mouse_opaque="true"
        name="gear_btn"
        tool_tip="My Camera Presets"
        top_delta="3"
        left_pad="10" 
        image_selected="Icon_Gear"
        image_pressed="Icon_Gear"
        image_unselected="Icon_Gear"
        is_toggle="true">
        <button.commit_callback
          function="CameraPresets.ShowPresetsList"/>
      </button>
      <button
        follows="top|left"
        height="25"
        label="Save as preset..."
        layout="topleft"
        left="0"
        name="save_preset_btn"
        top_pad="18"
        width="150">
        <button.commit_callback
          function="CameraPresets.Save"/>
      </button>
  </panel>
      </panel>

      <!-- TAB 2: Composition Guides -->
      <panel
       border="true"
       follows="all"
       height="150"
       label="Composition Guides"
       layout="topleft"
       left="1"
       name="tab_composition"
       top="20"
       width="388">

        <text
         type="string"
         length="1"
         follows="left|top"
         height="16"
         layout="topleft"
         left="10"
         top="5"
         width="370"
         font="SansSerifBold"
         text_color="White">
          Professional Composition Guides
        </text>

        <check_box
         control_name="CameraFramingEnabled"
         height="20"
         initial_value="false"
         label="Enable Framing Overlay"
         layout="topleft"
         left="20"
         top_pad="5"
         name="enable_framing"
         tool_tip="Show composition guides on screen for machinima"
         width="200" />

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left="20"
         top_pad="10"
         width="100">
          Guide Type:
        </text>

        <combo_box
         control_name="CameraFramingType"
         height="20"
         layout="topleft"
         left_pad="10"
         name="framing_type_combo"
         top_delta="-2"
         width="180">
          <combo_box.item
           label="Rule of Thirds"
           name="rule_of_thirds"
           value="0" />
          <combo_box.item
           label="Golden Ratio"
           name="golden_ratio"
           value="1" />
          <combo_box.item
           label="Center Cross"
           name="center_cross"
           value="2" />
          <combo_box.item
           label="Safe Zones (Action/Title)"
           name="safe_zones"
           value="3" />
          <combo_box.item
           label="Diagonal Lines"
           name="diagonal"
           value="4" />
          <combo_box.item
           label="Triangle Composition"
           name="triangle"
           value="5" />
        </combo_box>

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left="20"
         top_pad="10"
         width="100">
          Opacity:
        </text>

        <slider
         control_name="CameraFramingOpacity"
         follows="left|top"
         height="17"
         increment="0.05"
         initial_value="0.5"
         layout="topleft"
         left_pad="10"
         max_val="1.0"
         min_val="0.1"
         name="framing_opacity_slider"
         top_delta="-2"
         width="180" />

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left="20"
         top_pad="10"
         width="100">
          Frame Scale:
        </text>

        <slider
         control_name="CameraFramingScale"
         follows="left|top"
         height="17"
         increment="0.05"
         initial_value="1.0"
         layout="topleft"
         left_pad="10"
         max_val="2.0"
         min_val="0.5"
         name="framing_scale_slider"
         tool_tip="Zoom frame in/out - useful for adjusting golden ratio and other guides"
         top_delta="-2"
         width="180" />

      </panel>

      <!-- TAB 3: Camera Recorder -->
      <panel
       border="true"
       follows="all"
       height="150"
       label="Camera Recorder"
       layout="topleft"
       left="1"
       name="tab_recorder"
       top="20"
       width="388">

        <text
         type="string"
         length="1"
         follows="left|top"
         height="16"
         layout="topleft"
         left="10"
         top="5"
         width="370"
         font="SansSerifBold"
         text_color="White">
          Camera Path Recording
        </text>

        <!-- Recording Controls -->
        <button
         follows="left|top"
         height="25"
         label="⬤ Record"
         layout="topleft"
         left="20"
         top_pad="8"
         name="camera_record_btn"
         tool_tip="Record camera movement at 60fps (3600 keyframes for 60s = ~200KB). Camera unlocks from avatar during recording. Move smoothly for best results."
         width="110">
          <button.commit_callback
           function="CameraRecorder.Record"/>
        </button>

        <button
         follows="left|top"
         height="25"
         label="⏹ Stop"
         layout="topleft"
         left_pad="5"
         name="camera_stop_btn"
         tool_tip="Stop recording or playback"
         width="80">
          <button.commit_callback
           function="CameraRecorder.Stop"/>
        </button>

        <button
         follows="left|top"
         height="25"
         label="🗑 Clear"
         layout="topleft"
         left_pad="5"
         name="camera_clear_btn"
         tool_tip="Clear recorded camera path"
         width="80">
          <button.commit_callback
           function="CameraRecorder.Clear"/>
        </button>

        <!-- Playback Controls -->
        <button
         follows="left|top"
         height="25"
         label="▶ Play"
         layout="topleft"
         left="20"
         top_pad="8"
         name="camera_play_btn"
         tool_tip="Play recorded camera path. Avatar can move independently via keyboard or double-click walk during playback."
         width="110">
          <button.commit_callback
           function="CameraRecorder.Play"/>
        </button>

        <button
         follows="left|top"
         height="25"
         label="⏸ Pause"
         layout="topleft"
         left_pad="5"
         name="camera_pause_btn"
         tool_tip="Pause playback"
         width="80">
          <button.commit_callback
           function="CameraRecorder.Pause"/>
        </button>

        <!-- Status Display -->
        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left="20"
         top_pad="10"
         width="80"
         font="SansSerifSmall">
          Status:
        </text>

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left_pad="5"
         name="recorder_status_text"
         width="180"
         text_color="LtGray"
         font="SansSerifSmall">
          Ready
        </text>

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left="20"
         top_pad="2"
         width="80"
         font="SansSerifSmall">
          Time:
        </text>

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left_pad="5"
         name="recorder_time_text"
         width="180"
         text_color="LtGray"
         font="SansSerifSmall">
          0:00 / 0:00
        </text>

        <!-- Playback Options -->
        <check_box
         control_name="CameraRecorderLoop"
         height="20"
         initial_value="false"
         label="Loop playback"
         layout="topleft"
         left="310"
         top="40"
         name="recorder_loop_check"
         tool_tip="Automatically restart playback when finished"
         width="70" />

        <check_box
         control_name="CameraRecorderSmoothInterpolation"
         height="20"
         initial_value="false"
         label="Smooth"
         layout="topleft"
         left="310"
         top_pad="5"
         name="recorder_smooth_check"
         tool_tip="Enable smooth ease in/out interpolation. Disable for linear playback if experiencing stuttering."
         width="70" />

        <text
         type="string"
         follows="left|top"
         height="14"
         layout="topleft"
         left="310"
         top_pad="8"
         width="70"
         font="SansSerifSmall">
          Speed:
        </text>

        <combo_box
         control_name="CameraRecorderPlaybackSpeed"
         height="20"
         layout="topleft"
         left="310"
         name="playback_speed_combo"
         top_pad="2"
         width="70"
         initial_value="1.0">
          <combo_box.item
           label="0.25x"
           name="speed_025"
           value="0.25" />
          <combo_box.item
           label="0.5x"
           name="speed_05"
           value="0.5" />
          <combo_box.item
           label="1.0x"
           name="speed_10"
           value="1.0" />
          <combo_box.item
           label="1.5x"
           name="speed_15"
           value="1.5" />
          <combo_box.item
           label="2.0x"
           name="speed_20"
           value="2.0" />
        </combo_box>

      </panel>
    </tab_container>

  <panel
    name="viewer_camera_info"
    left="0"
    top="135"
    width="400"
    height="150"
    border="true"
    visible="false"
    background_visible="true"/>
  <panel
    name="agent_camera_info"
    left="0"
    top="285"
    width="400"
    height="150"
    border="true"
    visible="false"
    background_visible="true"/>
</floater>
