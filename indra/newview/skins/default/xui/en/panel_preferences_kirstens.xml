<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<panel
 border="true"
 follows="left|top|right|bottom"
 height="460"
 label="S24 prefs"
 layout="topleft"
 left="102"
 name="Display panel"
 top="1"
 width="517">

	<check_box
	  control_name="RenderDepthOfField"
	  height="16"
	  initial_value="true"
	  label="Toggle DOF effect"
	  layout="topleft"
	  top_pad="15"
	  left="10"
	  name="UseDOF"
	  tool_tip="Render Depth of Field."
	  width="315" />
	<text
	   name="deferred_label"
	   follows="left|top"
	   layout="topleft"
	   top_delta="0"
	   left_delta="180"
	   height="20"
	   width="150"
	   text_color="White_25">
		DOF fine control.
	</text>
	<slider
	 control_name="CameraFieldOfView"
	 can_edit_text="true"
	 decimal_digits="2"
	 follows="left|top"
	 height="16"
	 increment="1"
	 initial_value="60"
	 label="Camera FOV degs:"
	 label_width="160"
	 layout="topleft"
	 left="10"
	 max_val="200"
	 min_val="0"
	 name="Camera FOV"
 tool_tip="Vertical camera field of view for DoF effect (in degrees)"
	 top_pad="10"
	 width="324" />
	<slider
        control_name="CameraFNumber"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.5"
        initial_value="9.00"
        label="CameraFNumber f/#:"
        label_width="160"
        layout="topleft"
        left="10"
        max_val="128"
        min_val="0.50"
        name="CameraFNum"
	tool_tip="Camera f-number value for DoF effect"
        top_pad="5"
        width="324" />
	<slider
        control_name="CameraFocalLength"
        can_edit_text="true"
        decimal_digits="1"
        follows="left|top"
        height="16"
        increment="1"
        initial_value="50"
        label="Camera Focal Length mm:"
        label_width="160"
        layout="topleft"
        left="10"
        max_val="1000"
        min_val="0"
        name="CameraFocal"
	tool_tip="Camera focal length for DoF effect (in millimeters)"
        top_pad="5"
        width="324" />
	<slider
        control_name="CameraAspectRatio"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.01"
        initial_value="1.5"
        label="Camera Aspect Ratio:"
        label_width="160"
        layout="topleft"
        left="10"
        max_val="5"
        min_val="0"
        name="CameraAspectRatio"
	tool_tip="Camera aspect ratio for DoF effect"
        top_pad="5"
        width="324" />
	<slider
        control_name="CameraFocusTransitionTime"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.01"
        initial_value="0.5"
        label="DOF Focus Transition Time:"
        label_width="160"
        layout="topleft"
        left="10"
        max_val="20"
        min_val="0.01"
        name="CameraFocusTrans"
	tool_tip="Time taken to alter focus from one place to the next"
        top_pad="5"
        width="324" />
	<check_box
		control_name="StereoMode"
		height="16"
		initial_value="false"
		label="Toggle Anaglyph 3D"
		layout="topleft"
		top_pad="15"
		left="10"
		name="StereoMode"
		tool_tip="Enable red/cyan anaglyph stereoscopic 3D rendering (opt-in)"
		width="315" />
	<text
			name="stereo_label"
			follows="left|top"
			layout="topleft"
			top_delta="0"
			left_delta="180"
			height="20"
			width="150"
			text_color="White_25">
		Experimental (WIP).
	</text>
	<check_box
		control_name="StereoAutoAdjust"
		height="16"
		initial_value="true"
		label="Auto-Adjust Stereo (Recommended)"
		layout="topleft"
		top_pad="5"
		left="10"
		name="StereoAutoAdjust"
		tool_tip="Automatically adjust focal distance and strength based on camera zoom - no manual tweaking needed!"
		width="315" />
	<slider
		control_name="StereoEyeSeparation"
		can_edit_text="true"
		decimal_digits="3"
		follows="left|top"
		height="16"
		increment="0.001"
		initial_value="0.065"
		label="Eye Separation (IPD):"
		label_width="160"
		layout="topleft"
		left="10"
		max_val="0.080"
		min_val="0.050"
		name="StereoEyeSeparation"
	tool_tip="Inter-pupillary distance in meters (0.065m = 65mm typical adult, range 50-80mm)"
		top_pad="5"
		width="324" />
	<slider
		control_name="StereoStrength"
		can_edit_text="true"
		decimal_digits="2"
		follows="left|top"
		height="16"
		increment="0.05"
		initial_value="1.0"
		label="Stereo Strength:"
		label_width="160"
		layout="topleft"
		left="10"
		max_val="2.0"
		min_val="0.1"
		name="StereoStrength"
	tool_tip="3D effect strength multiplier (1.0 = normal, 0.5 = half for large monitors, 1.5 = enhanced)"
		top_pad="5"
		width="324" />
	<slider
		control_name="StereoFocalDistance"
		can_edit_text="true"
		decimal_digits="1"
		follows="left|top"
		height="16"
		increment="0.5"
		initial_value="10.0"
		label="Manual Focal Distance:"
		label_width="160"
		layout="topleft"
		left="10"
		max_val="30.0"
		min_val="-2.0"
		name="StereoFocalDistance"
	tool_tip="Convergence distance: NEGATIVE = dramatic pop-out (window violation - all objects in front of screen), 0m = at screen, 1-6m = sweet spot with strong depth, >6m = diminishing depth. Negative values can be tiring - use sparingly for dramatic effect!"
		top_pad="5"
		width="324" />
	<slider
		control_name="StereoMinFocalDistance"
		can_edit_text="true"
		decimal_digits="1"
		follows="left|top"
		height="16"
		increment="0.5"
		initial_value="4.0"
		label="Min Focal Distance (Safety):"
		label_width="160"
		layout="topleft"
		left="10"
		max_val="10.0"
		min_val="-2.0"
		name="StereoMinFocalDistance"
	tool_tip="Minimum auto-focal distance: Negative = experimental window violation (convergence behind camera), 0-4m = comfortable range, 4m+ = conservative. Lower values increase pop-out effect. Default 4m is safe for most users."
		top_pad="5"
		width="324" />
	<slider
		control_name="StereoFocalDistanceSmooth"
		can_edit_text="true"
		decimal_digits="2"
		follows="left|top"
		height="16"
		increment="0.05"
		initial_value="0.15"
		label="Focal Smoothing:"
		label_width="160"
		layout="topleft"
		left="10"
		max_val="0.95"
		min_val="0.01"
		name="StereoFocalSmooth"
	tool_tip="Auto-focal transition smoothness (0.01=instant/jittery, 0.15=balanced, 0.95=very smooth/laggy)"
		top_pad="5"
		width="324" />

	<slider
		  control_name="StereoZnear"
		  can_edit_text="true"
		  decimal_digits="2"
		  follows="left|top"
		  height="16"
		  increment="0.01"
		  initial_value="0.00"
		  label="Near Clip Offset:"
		  label_width="160"
		  layout="topleft"
		  left="10"
		  max_val="0.1"
		  min_val="0.0"
		  name="StereoZnear"
	  tool_tip="Near clipping plane offset in meters (advanced, usually keep at 0.0)"
		  top_pad="5"
		  width="324" />
	<slider
		  control_name="StereoFOVmultiplier"
		  can_edit_text="true"
		  decimal_digits="2"
		  follows="left|top"
		  height="16"
		  increment="0.01"
		  initial_value="0.5"
		  label="FOV Multiplier:"
		  label_width="160"
		  layout="topleft"
		  left="10"
		  max_val="0.8"
		  min_val="0.3"
		  name="Stereo FOV"
	  tool_tip="Field-of-view scaling factor (affects convergence strength and frustum width)"
		  top_pad="5"
		  width="324" />

	<check_box
	  control_name="WindowBorderless"
	  height="16"
	  initial_value="false"
	  label="Borderless Window Mode"
	  layout="topleft"
	  top_pad="5"
	  left="10"
	  name="WindowBorderless"
	  tool_tip="Enable borderless window (no titlebar/frame). Requires restart to take effect."
	  width="315" />
	<text
	   name="borderless_label"
	   follows="left|top"
	   layout="topleft"
	   top_delta="0"
	   left_delta="180"
	   height="20"
	   width="150"
	   text_color="LtYellow">
		Requires restart!
	</text>

	<text
	  type="string"
	  length="1"
	  follows="left|top"
	  height="15"
	  layout="topleft"
	  left="30"
	  name="skin_select_textbox"
	  top_pad="10"
	  width="400">
		S24 UI Selection - (Requires Restart):
	</text>
	<!-- S24 - Dynamic skin selector: replaces hardcoded radio buttons with combo box populated from skins folder -->
	<combo_box
		 control_name="SkinCurrent"
		 height="23"
		 layout="topleft"
		 left="35"
		 top_pad="5"
		 name="skin_selection"
		 width="200" />
	<button
		 follows="top|left"
		 height="23"
		 label="⚠ S24 Engine"
		 layout="topleft"
		 left_pad="10"
		 name="KVTweaks"
		 top_delta="0"
		 width="150"
		 font="SansSerifBold"
		 image_unselected="PushButton_On"
		 image_selected="PushButton_On_Selected"
		 tool_tip="Advanced performance tuning and low-level engine controls">
		<button.commit_callback
		  function="Pref.KVTweaks"
		  parameter="kvtweaks" />
	</button>
</panel>