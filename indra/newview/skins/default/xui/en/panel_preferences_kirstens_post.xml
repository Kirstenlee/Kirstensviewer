<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel border="true" follows="left|top|right|bottom" height="438"
label="S24 prefs" layout="topleft" left="102" name="Display panel"
top="1" width="517">

  <check_box control_name="UseDesaturation" height="16"
  initial_value="false" label="Black and White" layout="topleft"
  top_pad="15" left="10" name="UseDesaturation"
  tool_tip="Apply BW Render Effect." width="315" />

  <check_box control_name="UseInvert" height="16"
  initial_value="false" label="Invert" layout="topleft"
  top_pad="-17" left="150" name="UseInvert"
  tool_tip="Apply Inversion Of Render." width="315" />

  <check_box control_name="UseCelShade" height="16"
  initial_value="false" label="Cel Shade" layout="topleft"
  top_pad="10" left="10" name="UseCelShading"
  tool_tip="Apply Cel Shdaing To Render." width="315" />

  <slider
        control_name="CelshadeInterval"
        can_edit_text="true"
        decimal_digits="0"
        follows="left|top"
        height="16"
        increment="1"
        initial_value="128"
        label="Cel Pixel Interval:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="1024"
        min_val="32"
        name="Cel Interval"
	tool_tip="Number of colours devided into Cels"
        top_pad="-15"
        width="370" />
  <slider
        control_name="CelnumShades"
        can_edit_text="true"
        decimal_digits="0"
        follows="left|top"
        height="16"
        increment="1"
        initial_value="8"
        label="Cel Divisor:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="64"
        min_val="1"
        name="Cel Shades"
	tool_tip="Divisor for Cel Interval."
        top_pad="5"
        width="370" />

  <check_box control_name="UseVignette" height="16"
  initial_value="false" label="Vignette" layout="topleft"
  top_pad="10" left="10" name="UseVingnette"
  tool_tip="Apply Border To Render." width="315" />

  <slider
        control_name="VignetteIntensity"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.01"
        initial_value="0.8"
        label="Intensity:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="1.00"
        min_val="0.01"
        name="Vig Intensity"
	tool_tip="Strength of Vignette Effect."
        top_pad="-15"
        width="370" />

  <check_box control_name="UseNightVision" height="16"
  initial_value="false" label="NightVision" layout="topleft"
  top_pad="15" left="10" name="UseNightVision"
  tool_tip="Apply Green S19 Effect." width="315" />

  <slider
        control_name="greenIntensity"
        can_edit_text="true"
        decimal_digits="1"
        follows="left|top"
        height="16"
        increment="0.1"
        initial_value="1.5"
        label="Intensity:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="4.0"
        min_val="0.1"
        name="Green Intensity"
	tool_tip="Green Multiplier"
        top_pad="-15"
        width="370" />
  <slider
        control_name="brightnessBoost"
        can_edit_text="true"
        decimal_digits="0"
        follows="left|top"
        height="16"
        increment="1"
        initial_value="30"
        label="Boost:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="100"
        min_val="1"
        name="Brightness Boost"
	tool_tip="0-100 Boost To Brightness."
        top_pad="5"
        width="370" />

  <slider
        control_name="noiseScale"
        can_edit_text="true"
        decimal_digits="0"
        follows="left|top"
        height="16"
        increment="1"
        initial_value="2"
        label="Noise Scale:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="16"
        min_val="1"
        name="Noise Scale"
	tool_tip="How Much Noise Effect."
        top_pad="5"
        width="370" />

  <check_box control_name="UseEdgeGlow" height="16"
 initial_value="false" label="EdgeGlow" layout="topleft"
 top_pad="10" left="10" name="UseEdgeGlow"
 tool_tip="Apply Sobel Glow Effect." width="315" />

  <slider
        control_name="edgeSensitivity"
        can_edit_text="true"
        decimal_digits="1"
        follows="left|top"
        height="16"
        increment="0.1"
        initial_value="1.0"
        label="Sensitivity:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="3"
        min_val="0.1"
        name="Sensitivity"
	tool_tip="Edge Detection."
        top_pad="-15"
        width="370" />

  <slider
        control_name="edgeGlowIntensity"
        can_edit_text="true"
        decimal_digits="1"
        follows="left|top"
        height="16"
        increment="0.1"
        initial_value="5.0"
        label="Intensity:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="10.0"
        min_val="1.0"
        name="GlowIntensity"
	tool_tip="Glow Intensity."
        top_pad="5"
        width="370" />

  <slider
		control_name="edgeBlurRadius"
		can_edit_text="true"
		decimal_digits="1"
		follows="left|top"
		height="16"
		increment="0.1"
		initial_value="1.0"
		label="Edge Blur:"
		label_width="100"
		layout="topleft"
		left="120"
		max_val="5.0"
		min_val="0.0"
		name="Edge Blur"
	tool_tip="Edge Smoothing."
		top_pad="5"
		width="370" />

  <check_box control_name="UseMotionBlur" height="16"
  initial_value="false" label="Motion Blur" layout="topleft"
  top_pad="15" left="10" name="UseMotionBlur"
  tool_tip="Apply Motion Blur Effect with Frame Accumulation." width="315" />

  <slider
		control_name="MotionBlurBlend"
		can_edit_text="true"
		decimal_digits="2"
		follows="left|top"
		height="16"
		increment="0.01"
		initial_value="0.7"
		label="Blur Amount:"
		label_width="100"
		layout="topleft"
		left="120"
		max_val="1.0"
		min_val="0.0"
		name="Motion Blur Blend"
	tool_tip="0.0 = Maximum trail, 1.0 = No blur"
		top_pad="-15"
		width="370" />

  <check_box control_name="UseRGBControl" height="16"
initial_value="false" label="RGB Twister" layout="topleft"
top_pad="15" left="10" name="UseRGBControl"
tool_tip="Twist RGB at will! CPU intensive." width="315" />

  <slider
      control_name="RedControlKV"
      can_edit_text="true"
      decimal_digits="2"
      follows="left|top"
      height="16"
      increment="0.01"
      initial_value="1.0"
      label="Red Control:"
      label_width="100"
      layout="topleft"
      left="120"
      max_val="10.0"
      min_val="-10.0"
      name="Red Control"
      tool_tip="Adjust intensity of the red channel."
      top_pad="-15"
      width="370" />

  <slider
        control_name="GreenControlKV"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.01"
        initial_value="1.0"
        label="Green Control:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="10.0"
        min_val="-10.0"
        name="Green Control"
        tool_tip="Adjust intensity of the green channel."
        top_pad="5"
        width="370" />

  <slider
        control_name="BlueControlKV"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.01"
        initial_value="1.0"
        label="Blue Control:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="10.0"
        min_val="-10.0"
        name="Blue Control"
        tool_tip="Adjust intensity of the blue channel."
        top_pad="5"
        width="370" />

  <slider
        control_name="BoostMultiplierKV"
        can_edit_text="true"
        decimal_digits="2"
        follows="left|top"
        height="16"
        increment="0.01"
        initial_value="1.0"
        label="Boost:"
        label_width="100"
        layout="topleft"
        left="120"
        max_val="5.0"
        min_val="-5.0"
        name="Boost Multiplier"
        tool_tip="Global multiplier for RGB adjustments."
        top_pad="5"
        width="370" />

  <slider
    control_name="HueRotationKV"
    can_edit_text="true"
    decimal_digits="1"
    follows="left|top"
    height="16"
    increment="1.0"
    initial_value="0.0"
    label="Hue Rotation:"
    label_width="100"
    layout="topleft"
    left="120"
    max_val="360.0"
    min_val="0.0"
    name="Hue Rotation"
    tool_tip="Rotate the hue of the image (0-360 degrees)."
    top_pad="5"
    width="370" />

  <slider
      control_name="SaturationControlKV"
      can_edit_text="true"
      decimal_digits="2"
      follows="left|top"
      height="16"
      increment="0.01"
      initial_value="1.0"
      label="Saturation:"
      label_width="100"
      layout="topleft"
      left="120"
      max_val="2.0"
      min_val="0.0"
      name="Saturation Control"
      tool_tip="Adjust the saturation of the image."
      top_pad="5"
      width="370" />

  <slider
      control_name="ContrastMultiplierKV"
      can_edit_text="true"
      decimal_digits="2"
      follows="left|top"
      height="16"
      increment="0.01"
      initial_value="1.0"
      label="Contrast:"
      label_width="100"
      layout="topleft"
      left="120"
      max_val="3.0"
      min_val="0.5"
      name="Contrast Multiplier"
      tool_tip="Adjust the contrast of the image."
      top_pad="5"
      width="370" />

  <slider
      control_name="GammaCorrectionKV"
      can_edit_text="true"
      decimal_digits="2"
      follows="left|top"
      height="16"
      increment="0.01"
      initial_value="1.0"
      label="Gamma:"
      label_width="100"
      layout="topleft"
      left="120"
      max_val="3.0"
      min_val="0.5"
      name="Gamma Correction"
      tool_tip="Apply gamma correction to the image."
      top_pad="5"
      width="370" />
</panel>